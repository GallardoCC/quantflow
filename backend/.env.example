# Copia este archivo a .env y rellena tus keys (planes gratuitos).
# NUNCA subas el .env real a git (ya está en .gitignore).

# FMP -> https://financialmodelingprep.com  (quote + búsqueda + calendario)
FMP_API_KEY=
# Finnhub -> https://finnhub.io  (tiempo real + noticias)
FINNHUB_API_KEY=
# Alpha Vantage -> https://www.alphavantage.co  (indicadores técnicos)
ALPHAVANTAGE_API_KEY=
# FRED -> https://fred.stlouisfed.org  (macro EE.UU. + calendario)
FRED_API_KEY=
# Alpaca Markets -> https://alpaca.markets  (order flow, paper trading)
ALPACA_API_KEY=
ALPACA_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
